{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.scryfall.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.edhrec.com/*",
        "*://*.archidekt.com/*",
        "*://*.tappedout.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },
  "icons": {
    "48": "icons/icon-48.svg"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
