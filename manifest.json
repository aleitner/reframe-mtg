{
  "manifest_version": 2,
  "name": "__MSG_extName__",
  "version": "1.2.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab",
    "https://api.scryfall.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "reframe-mtg@extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.edhrec.com/*",
        "*://*.archidekt.com/*",
        "*://*.tappedout.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg"
    }
  },
  "icons": {
    "48": "icons/icon-48.svg"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
